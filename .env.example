# =============================================================================
# LFG MVP Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# For Docker Compose, place this file in the project root

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Required: PostgreSQL connection string
# Format: postgresql://user:password@host:port/dbname?sslmode=disable
# If using docker-compose with local-db profile, this will be auto-generated
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lfg_mvp?sslmode=disable

# Optional: Individual database settings (used by docker-compose)
# Only needed if using the local PostgreSQL service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=lfg_mvp
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
# Required: Backend API URL for frontend build
# This is baked into the frontend at build time
# Use https:// for production, http://localhost:8080 for local dev
VITE_BACKEND_URL=https://findparty.online

# -----------------------------------------------------------------------------
# Authentication Configuration
# -----------------------------------------------------------------------------
# Required: Secret key for signing session cookies
# Generate a long random string (at least 32 characters)
# Example: openssl rand -hex 32
AUTH_JWT_SECRET=your_long_random_secret_key_here_minimum_32_chars

# Optional: Path for file-based auth store (fallback if DATABASE_URL fails)
# Default: data/auth.json
# For Docker: /data/auth.json (persisted in volume)
AUTH_DB_PATH=/data/auth.json

# Optional: Session cookie name
# Default: lfg_session
AUTH_COOKIE_NAME=lfg_session

# Optional: Cookie domain for cross-subdomain support
# Use .findparty.online (with leading dot) to support www and non-www
# Leave empty for localhost
AUTH_COOKIE_DOMAIN=.findparty.online

# Optional: Enable Secure flag for cookies (HTTPS only)
# Set to "true" for production (HTTPS), "false" for local development
AUTH_COOKIE_SECURE=true

# Optional: Session duration in days
# Default: 365 (1 year)
AUTH_SESSION_TTL_DAYS=365

# -----------------------------------------------------------------------------
# OAuth Provider Configuration
# -----------------------------------------------------------------------------
# Required: Frontend URL for OAuth redirects
FRONTEND_URL=https://findparty.online

# Required: Backend URL for OAuth callbacks
BACKEND_URL=https://findparty.online

# Discord OAuth (Required if using Discord login)
# Get from: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Steam OAuth (Required if using Steam login)
# Get from: https://steamcommunity.com/dev/apikey
STEAM_WEB_API_KEY=your_steam_web_api_key

# Telegram OAuth (Required if using Telegram login)
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Optional: Telegram bot username/ID override
# If not set, backend will query getMe using the token
TELEGRAM_BOT_ID=your_telegram_bot_id

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Optional: Server port
# Default: 8080
PORT=8080

# Optional: CORS allowed origins (comma-separated)
# Default: hardcoded in main.go
# Format: https://example.com,https://www.example.com
ALLOWED_ORIGINS=https://findparty.online,https://www.findparty.online

# Optional: Gin mode (debug or release)
# Default: release
GIN_MODE=release
